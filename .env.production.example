# ┌──────────────────────────────────────────────────────────────────┐
# │  Teki — Variáveis de Ambiente (Produção)                        │
# │  Copie para .env.production e preencha os valores               │
# └──────────────────────────────────────────────────────────────────┘

# ── Banco de Dados ────────────────────────────────────────────────
# Gerenciado pelo docker-compose (não precisa alterar se usar o compose padrão)
# DATABASE_URL=postgresql://teki:SENHA@postgres:5432/teki
# DIRECT_URL=postgresql://teki:SENHA@postgres:5432/teki
POSTGRES_PASSWORD=TROCAR_POR_SENHA_FORTE

# ── Autenticação ──────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=https://teki.seudominio.com
NEXT_PUBLIC_APP_URL=https://teki.seudominio.com

# ── Segurança ─────────────────────────────────────────────────────
# Chave AES-256 para criptografia de API keys dos providers
# Gerar com: openssl rand -hex 32
PROVIDER_KEY_ENCRYPTION_KEY=

# ── Node ──────────────────────────────────────────────────────────
NODE_ENV=production

# ── Storage (Supabase) ────────────────────────────────────────────
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Provedores de IA (pelo menos 1 obrigatório) ──────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# ── Email (opcional) ──────────────────────────────────────────────
# RESEND_API_KEY=
# EMAIL_FROM=Teki <acesso@teki.com.br>

# ── Pagamento (opcional) ──────────────────────────────────────────
# BILLING_MODE=abacatepay
# ABACATEPAY_API_KEY=
# ABACATEPAY_WEBHOOK_SECRET=

# ── OAuth (opcional) ──────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Webhooks ──────────────────────────────────────────────────────
OPENCLAW_WEBHOOK_SECRET=trocar-por-secret-forte
# WHATSAPP_VERIFY_TOKEN=
# META_APP_SECRET=

# ── Busca (opcional) ──────────────────────────────────────────────
# NEXT_PUBLIC_ALGOLIA_APP_ID=
# NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
# NEXT_PUBLIC_ALGOLIA_AGENT_ID=
# ALGOLIA_ADMIN_KEY=
