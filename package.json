{
  "name": "teki",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx scripts/dev.ts",
    "dev:web": "pnpm --filter @teki/web dev",
    "dev:desktop": "cross-env NODE_ENV=development tsx scripts/dev.ts --target=desktop",
    "dev:free": "pnpm dev --plan=free --seed=basic",
    "dev:starter": "pnpm dev --plan=starter --seed=basic",
    "dev:pro": "pnpm dev --plan=pro --seed=full",
    "dev:enterprise": "pnpm dev --plan=enterprise --seed=full",
    "dev:onboarding": "pnpm dev --plan=free --seed=empty",
    "dev:limits": "pnpm dev --plan=starter --seed=limit",
    "seed": "tsx scripts/seed.ts",
    "seed:reset": "tsx scripts/seed.ts --reset",
    "build:web": "pnpm --filter @teki/web build",
    "build:desktop": "pnpm --filter @teki/desktop build",
    "build": "pnpm -r build",
    "start:web": "pnpm --filter @teki/web start",
    "dev:admin": "pnpm --filter @teki/admin dev",
    "build:admin": "pnpm --filter @teki/admin build",
    "start:admin": "pnpm --filter @teki/admin start"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "*"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0"
  }
}
