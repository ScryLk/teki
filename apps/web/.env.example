# ─── Database ───
DATABASE_URL=postgresql://user:pass@host:5432/teki?pgbouncer=true
DIRECT_URL=postgresql://user:pass@host:5432/teki

# ─── Auth ───
NEXTAUTH_SECRET=random-secret-32-chars-minimum
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=random-secret-32-chars-minimum

# ─── AI Providers (server-side, Teki keys) ───
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Ollama (optional, local) ───
OLLAMA_BASE_URL=http://localhost:11434

# ─── File Storage (Supabase) ───
SUPABASE_URL=https://xyz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── AbacatePay ───
ABACATEPAY_API_KEY=your-abacatepay-api-key
BILLING_MODE=abacatepay

# ─── Mercado Pago (legacy) ───
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
# MERCADOPAGO_WEBHOOK_SECRET=whsec-...

# ─── Encryption (64-char hex string for AES-256-GCM) ───
PROVIDER_KEY_ENCRYPTION_KEY=64-char-hex-string-here

# ─── WhatsApp (Meta) ───
META_APP_SECRET=abcdef...
WHATSAPP_VERIFY_TOKEN=your-verify-token

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
