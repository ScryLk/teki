generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ═══════════════════════════════════════════════════════════════
// TENANTS — Empresas/organizacoes na plataforma
// ═══════════════════════════════════════════════════════════════

model Tenant {
  id   String @id @default(uuid()) @db.Uuid
  name String @db.VarChar(200)
  slug String @unique @db.VarChar(100)

  // Contato da empresa
  email   String? @db.VarChar(255)
  phone   String? @db.VarChar(20)
  website String? @db.VarChar(500)

  // Localizacao (timezone padrao e compliance por jurisdicao)
  country         String  @default("BR") @db.VarChar(2)
  state           String? @db.VarChar(100)
  city            String? @db.VarChar(100)
  defaultTimezone String  @default("America/Sao_Paulo") @map("default_timezone") @db.VarChar(50)
  defaultLocale   String  @default("pt-BR") @map("default_locale") @db.VarChar(10)

  // Documentos fiscais
  taxId     String? @map("tax_id") @db.VarChar(20)
  taxIdType String? @map("tax_id_type") @db.VarChar(10)

  // Plano e billing
  plan             PlanTier  @default(FREE)
  planStartedAt    DateTime? @map("plan_started_at")
  planExpiresAt    DateTime? @map("plan_expires_at")
  billingEmail     String?   @map("billing_email") @db.VarChar(255)
  stripeCustomerId String?   @map("stripe_customer_id") @db.VarChar(255)
  mpPreapprovalId  String?   @map("mp_preapproval_id")

  // Estado
  status      TenantStatus @default(ACTIVE)
  trialEndsAt DateTime?    @map("trial_ends_at")

  // Settings (branding, security, features)
  settings Json @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  members          TenantMember[]
  dataPolicy       TenantDataPolicy?
  sessions         UserSession[]
  preferences      UserPreference[]
  conversations    Conversation[]
  conversationTags ConversationTag[]

  // Relations - External Connectors
  externalConnectors ExternalConnector[]
  slaPolicies        SlaPolicy[]

  // Relations - Notifications
  notifications             Notification[]
  notificationPrefOverrides NotificationPreferencesOverride[]

  // Relations - AI Config
  aiProviderConfigs AiProviderConfig[]
  aiUsageDaily      AiUsageDaily[]
  aiRoutingRules    AiRoutingRules?

  // Relations - Templates
  responseTemplates ResponseTemplate[]

  @@index([slug])
  @@index([plan, status])
  @@index([status])
  @@map("tenants")
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum PlanTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// ═══════════════════════════════════════════════════════════════
// USERS — Identidade central (LGPD Art. 7, II)
// Dados minimos: id, email, nome, status
// ═══════════════════════════════════════════════════════════════

model User {
  id    String @id @default(uuid()) @db.Uuid
  email String @unique @db.VarChar(255)

  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")

  firstName   String  @map("first_name") @db.VarChar(100)
  lastName    String? @map("last_name") @db.VarChar(100)
  displayName String? @map("display_name") @db.VarChar(200)

  phone         String? @unique @db.VarChar(20)
  phoneVerified Boolean @default(false) @map("phone_verified")

  avatarUrl String? @map("avatar_url") @db.VarChar(500)

  // Verificacao de email
  emailVerificationTokenHash String? @map("email_verification_token_hash") @db.VarChar(255)

  // Estado do ciclo de vida
  status UserStatus @default(PENDING_VERIFICATION)

  // Metadata do ciclo
  lastLoginAt        DateTime? @map("last_login_at")
  lastLoginIp        String?   @map("last_login_ip")
  lastLoginUserAgent String?   @map("last_login_user_agent") @db.Text

  deactivatedAt     DateTime? @map("deactivated_at")
  deactivatedReason String?   @map("deactivated_reason") @db.VarChar(500)
  anonymizedAt      DateTime? @map("anonymized_at")
  anonymizedBy      String?   @map("anonymized_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations - Auth
  credentials   UserCredential?
  authProviders UserAuthProvider[]

  // Relations - Operational
  memberships TenantMember[]   @relation("UserMemberships")
  invitations TenantMember[]   @relation("UserInvitations")
  preferences UserPreference[]
  sessions    UserSession[]
  consents    UserConsent[]

  // Relations - Data access (as subject)
  dataAccessAsSubject DataAccessLog[] @relation("DataAccessSubject")

  // Relations - Existing features (preserved)
  agents           Agent[]
  channels         Channel[]
  apiKeys          ApiKey[]
  usageCounters    UsageCounter[]
  providerKeys     ProviderKey[]
  webhookEndpoints WebhookEndpoint[]
  documents        Document[]
  kbArticles       KbArticle[]
  kbCategories     KbCategory[]
  kbInsertionLogs  KbInsertionLog[]

  // Relations - Conversations (new schema)
  createdConversations ConversationParticipant[]
  conversationsCreated Conversation[]            @relation("ConversationCreator")
  sentMessages         Message[]                 @relation("MessageSender")
  messageFeedback      MessageFeedback[]
  uploadedAttachments  MessageAttachment[]       @relation("AttachmentUploader")
  createdTags          ConversationTag[]         @relation("TagCreator")
  tagLinks             ConversationTagLink[]     @relation("TagLinkUser")

  // Relations - External Connectors
  configuredConnectors  ExternalConnector[]    @relation("ConnectorConfigurator")
  connectorUserMappings ConnectorUserMapping[]

  // Relations - Notifications
  notificationsReceived     Notification[]                    @relation("NotificationRecipient")
  notificationsCaused       Notification[]                    @relation("NotificationActor")
  notificationPrefOverrides NotificationPreferencesOverride[]

  // Relations - AI Config
  aiProviderConfigsConfigured AiProviderConfig[] @relation("AiConfigConfigurator")

  // Relations - Templates
  responseTemplatesCreated  ResponseTemplate[] @relation("TemplateCreator")
  responseTemplatesUpdated  ResponseTemplate[] @relation("TemplateUpdater")
  responseTemplatesLastUsed ResponseTemplate[] @relation("TemplateLastUser")
  templateUsageLogs         TemplateUsageLog[]

  @@index([email])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([lastLoginAt(sort: Desc)])
  @@map("users")
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED
  ANONYMIZED
}

// ═══════════════════════════════════════════════════════════════
// USER_CREDENTIALS — Hash de senhas (auth local)
// Base legal LGPD: Art. 7, II + Art. 46 (seguranca)
// Separada do users por isolamento de seguranca
// ═══════════════════════════════════════════════════════════════

model UserCredential {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  // Hash: argon2id ou bcrypt
  passwordHash  String        @map("password_hash") @db.VarChar(255)
  hashAlgorithm HashAlgorithm @default(ARGON2ID) @map("hash_algorithm")

  // Politica de senha
  passwordChangedAt  DateTime  @default(now()) @map("password_changed_at")
  passwordExpiresAt  DateTime? @map("password_expires_at")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  failedAttempts     Int       @default(0) @map("failed_attempts")
  lockedUntil        DateTime? @map("locked_until")

  // MFA
  mfaEnabled              Boolean    @default(false) @map("mfa_enabled")
  mfaMethod               MfaMethod? @map("mfa_method")
  mfaSecretEncrypted      String?    @map("mfa_secret_encrypted") @db.VarChar(500)
  mfaBackupCodesEncrypted String?    @map("mfa_backup_codes_encrypted") @db.Text
  mfaVerifiedAt           DateTime?  @map("mfa_verified_at")

  // Recovery
  recoveryTokenHash      String?   @map("recovery_token_hash") @db.VarChar(255)
  recoveryTokenExpiresAt DateTime? @map("recovery_token_expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_credentials")
}

enum HashAlgorithm {
  ARGON2ID
  BCRYPT
}

enum MfaMethod {
  TOTP
  SMS
  EMAIL
}

// ═══════════════════════════════════════════════════════════════
// USER_AUTH_PROVIDERS — Conexoes OAuth e SSO
// Base legal LGPD: Art. 7, II (execucao de contrato)
// Um user pode ter N providers vinculados
// ═══════════════════════════════════════════════════════════════

model UserAuthProvider {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  // Provider
  provider       AuthProvider @default(GOOGLE)
  providerUserId String       @map("provider_user_id") @db.VarChar(255)

  // Tokens (criptografados AES-256-GCM)
  accessTokenEncrypted  String?   @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String?   @map("refresh_token_encrypted") @db.Text
  tokenExpiresAt        DateTime? @map("token_expires_at")

  // Dados do provider (snapshot do ultimo login)
  providerEmail     String? @map("provider_email") @db.VarChar(255)
  providerName      String? @map("provider_name") @db.VarChar(200)
  providerAvatarUrl String? @map("provider_avatar_url") @db.VarChar(500)

  // SSO especifico (SAML/OIDC)
  ssoTenantId  String? @map("sso_tenant_id") @db.VarChar(255)
  ssoIssuerUrl String? @map("sso_issuer_url") @db.VarChar(500)
  ssoMetadata  Json?   @map("sso_metadata")

  // Estado
  isPrimary  Boolean   @default(false) @map("is_primary")
  linkedAt   DateTime  @default(now()) @map("linked_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Um user nao pode vincular o mesmo provider duas vezes
  @@unique([userId, provider, providerUserId])
  // Garante que o provider_user_id nao esta vinculado a outro user
  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([ssoTenantId])
  @@map("user_auth_providers")
}

enum AuthProvider {
  GOOGLE
  GITHUB
  MICROSOFT
  SAML
  OIDC
}

// ═══════════════════════════════════════════════════════════════
// TENANT_MEMBERS — Vinculo user <-> tenant
// Base legal LGPD: Art. 7, II (execucao de contrato)
// Um user pode pertencer a N tenants com roles diferentes
// ═══════════════════════════════════════════════════════════════

model TenantMember {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid

  // Role no tenant
  role MemberRole @default(AGENT)

  // Permissoes granulares (para role CUSTOM ou override)
  permissions Json?

  // Contexto no tenant
  jobTitle   String? @map("job_title") @db.VarChar(100)
  department String? @db.VarChar(100)

  // Estado do vinculo
  status MemberStatus @default(ACTIVE)

  // Convite
  invitedBy       String?   @map("invited_by") @db.Uuid
  invitedAt       DateTime? @map("invited_at")
  inviteTokenHash String?   @map("invite_token_hash") @db.VarChar(255)
  inviteExpiresAt DateTime? @map("invite_expires_at")
  acceptedAt      DateTime? @map("accepted_at")

  // Metadata operacional
  lastActiveAt DateTime? @map("last_active_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User   @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)
  invitedByUser User?  @relation("UserInvitations", fields: [invitedBy], references: [id])

  @@unique([tenantId, userId])
  @@index([tenantId, status])
  @@index([userId, status])
  @@index([tenantId, role])
  @@index([inviteTokenHash])
  @@index([tenantId, lastActiveAt(sort: Desc)])
  @@map("tenant_members")
}

enum MemberRole {
  OWNER
  ADMIN
  AGENT
  VIEWER
  BILLING
  CUSTOM
}

enum MemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

// ═══════════════════════════════════════════════════════════════
// USER_PREFERENCES — Preferencias por user + tenant
// Base legal LGPD: Art. 7, I (consentimento) para dados opcionais
// ═══════════════════════════════════════════════════════════════

model UserPreference {
  id       String  @id @default(uuid()) @db.Uuid
  userId   String  @map("user_id") @db.Uuid
  tenantId String? @map("tenant_id") @db.Uuid

  // Preferencias estruturadas
  timezone             String  @default("America/Sao_Paulo") @db.VarChar(50)
  timezoneAutoDetected Boolean @default(true) @map("timezone_auto_detected")
  locale               String  @default("pt-BR") @db.VarChar(10)
  theme                Theme   @default(DARK)

  // Preferencias extensiveis (JSONB)
  notificationSettings Json @default("{\"email\":{\"enabled\":true,\"digest\":\"daily\",\"types\":[\"ticket_assigned\",\"ticket_resolved\",\"mention\"]},\"desktop\":{\"enabled\":true,\"sound\":true,\"types\":[\"ticket_assigned\",\"new_message\",\"alert\"]},\"in_app\":{\"enabled\":true,\"types\":[\"all\"]}}") @map("notification_settings")
  aiSettings           Json @default("{\"preferred_provider\":null,\"preferred_model\":null,\"auto_suggest\":true,\"suggestion_language\":\"pt-BR\",\"show_cost\":true,\"show_tokens\":false}") @map("ai_settings")

  floatingAssistantSettings Json @default("{\"side\":\"right\",\"width\":320,\"collapsed\":false,\"always_on_top\":true,\"opacity\":0.85,\"stealth_mode\":true,\"shortcuts\":{\"toggle\":\"CommandOrControl+Shift+Space\",\"capture\":\"CommandOrControl+Shift+S\",\"audio\":\"CommandOrControl+Shift+A\",\"quick_input\":\"CommandOrControl+Shift+Q\"}}") @map("floating_assistant_settings")

  uiSettings Json @default("{\"sidebar_collapsed\":false,\"density\":\"comfortable\",\"font_size\":\"medium\",\"animations\":true,\"cat_mascot_visible\":true,\"keyboard_shortcuts_enabled\":true,\"default_kb_view\":\"list\",\"default_ticket_view\":\"kanban\"}") @map("ui_settings")

  // Bucket generico para features futuras
  customSettings Json @default("{}") @map("custom_settings")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([userId, tenantId])
  @@map("user_preferences")
}

enum Theme {
  DARK
  LIGHT
  SYSTEM
}

// ═══════════════════════════════════════════════════════════════
// USER_CONSENTS — Registros de consentimento (LGPD Art. 8)
// IMUTAVEL: cada mudanca cria novo registro, nunca UPDATE
// ═══════════════════════════════════════════════════════════════

model UserConsent {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  // Tipo de consentimento
  purpose ConsentPurpose

  // Decisao
  granted Boolean

  // Contexto legal
  legalBasis LegalBasis @map("legal_basis")

  // Versao do documento aceito
  policyVersion String  @map("policy_version") @db.VarChar(20)
  policyUrl     String? @map("policy_url") @db.VarChar(500)

  // Como foi coletado
  collectionMethod ConsentCollectionMethod @map("collection_method")

  // Metadados do momento da coleta (prova)
  ipAddress  String? @map("ip_address")
  userAgent  String? @map("user_agent") @db.Text
  geoCountry String? @map("geo_country") @db.VarChar(2)

  // Validade
  expiresAt DateTime? @map("expires_at")

  // Imutavel - sem updated_at
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, createdAt(sort: Desc)])
  @@index([purpose, granted])
  @@index([createdAt(sort: Desc)])
  @@map("user_consents")
}

enum ConsentPurpose {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  DATA_PROCESSING
  AI_DATA_USAGE
  MARKETING_EMAIL
  ANALYTICS_TRACKING
  THIRD_PARTY_SHARING
  AUDIO_RECORDING
  SCREEN_CAPTURE
  COOKIE_ANALYTICS
  COOKIE_MARKETING
}

enum LegalBasis {
  CONSENT
  CONTRACT
  LEGAL_OBLIGATION
  LEGITIMATE_INTEREST
}

enum ConsentCollectionMethod {
  SIGNUP_FORM
  BANNER
  SETTINGS
  PROMPT
  API
  MIGRATION
}

// ═══════════════════════════════════════════════════════════════
// DATA_ACCESS_LOG — Quem acessou dados pessoais de quem
// LGPD: Art. 37 (registro de tratamento) + Art. 46 (seguranca)
// RETENCAO MINIMA: 5 anos (prazo prescricional LGPD)
// ═══════════════════════════════════════════════════════════════

model DataAccessLog {
  id String @id @default(uuid()) @db.Uuid

  // Quem acessou
  accessorId       String       @map("accessor_id") @db.Uuid
  accessorType     AccessorType @map("accessor_type")
  accessorTenantId String?      @map("accessor_tenant_id") @db.Uuid

  // De quem foram os dados acessados
  subjectId String @map("subject_id") @db.Uuid

  // O que foi acessado
  action DataAccessAction

  // Quais dados foram acessados
  dataCategories String[] @map("data_categories")

  // Detalhes
  details Json?

  // Justificativa legal
  legalBasis    String? @map("legal_basis") @db.VarChar(50)
  justification String? @db.Text

  // Metadados
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent") @db.Text

  // Imutavel - sem updated_at
  createdAt DateTime @default(now()) @map("created_at")

  subject User @relation("DataAccessSubject", fields: [subjectId], references: [id])

  @@index([subjectId, createdAt(sort: Desc)])
  @@index([accessorId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("data_access_log")
}

enum AccessorType {
  USER
  ADMIN
  SYSTEM
  API_ACCESSOR
  SUPPORT
}

enum DataAccessAction {
  VIEW
  EXPORT
  MODIFY
  DELETE
  ANONYMIZE
  SHARE
  PROCESS
}

// ═══════════════════════════════════════════════════════════════
// TENANT_DATA_POLICIES — Configuracao de retencao e exclusao
// Configuravel pelo owner do tenant
// ═══════════════════════════════════════════════════════════════

model TenantDataPolicy {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @unique @map("tenant_id") @db.Uuid

  // Comportamento ao remover usuario do tenant
  memberRemovalPolicy MemberRemovalPolicy @default(ANONYMIZE) @map("member_removal_policy")

  // Se RETAIN: quantos dias manter antes de aplicar
  retentionDays Int @default(30) @map("retention_days")

  // Dados operacionais: manter ou apagar junto?
  keepTickets      Boolean @default(true) @map("keep_tickets")
  keepKbArticles   Boolean @default(true) @map("keep_kb_articles")
  keepActivityLogs Boolean @default(true) @map("keep_activity_logs")
  keepAiHistory    Boolean @default(false) @map("keep_ai_history")

  // LGPD: tempo de retencao geral de dados pessoais no tenant
  personalDataRetentionMonths Int @default(24) @map("personal_data_retention_months")

  // Notificacoes
  notifyUserOnDataDeletion Boolean @default(true) @map("notify_user_on_data_deletion")
  notifyAdminOnDataRequest Boolean @default(true) @map("notify_admin_on_data_request")

  // DPO (Data Protection Officer)
  dpoName  String? @map("dpo_name") @db.VarChar(200)
  dpoEmail String? @map("dpo_email") @db.VarChar(255)

  // Termos aceitos pelo owner
  termsAcceptedAt DateTime? @map("terms_accepted_at")
  termsAcceptedBy String?   @map("terms_accepted_by") @db.Uuid
  termsVersion    String?   @map("terms_version") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_data_policies")
}

enum MemberRemovalPolicy {
  ANONYMIZE
  HARD_DELETE
  RETAIN
}

// ═══════════════════════════════════════════════════════════════
// USER_SESSIONS — Sessoes ativas
// Multi-device, revogacao remota, deteccao de anomalia
// ═══════════════════════════════════════════════════════════════

model UserSession {
  id       String  @id @default(uuid()) @db.Uuid
  userId   String  @map("user_id") @db.Uuid
  tenantId String? @map("tenant_id") @db.Uuid

  // Token
  tokenHash        String  @unique @map("token_hash") @db.VarChar(255)
  refreshTokenHash String? @unique @map("refresh_token_hash") @db.VarChar(255)

  // Device info
  deviceFingerprint String?     @map("device_fingerprint") @db.VarChar(255)
  deviceType        DeviceType? @map("device_type")
  deviceName        String?     @map("device_name") @db.VarChar(100)
  os                String?     @db.VarChar(50)
  browser           String?     @db.VarChar(50)

  // Localizacao
  ipAddress  String  @map("ip_address")
  geoCountry String? @map("geo_country") @db.VarChar(2)
  geoRegion  String? @map("geo_region") @db.VarChar(100)
  geoCity    String? @map("geo_city") @db.VarChar(100)

  // Estado
  isActive       Boolean  @default(true) @map("is_active")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  expiresAt      DateTime @map("expires_at")

  revokedAt    DateTime?            @map("revoked_at")
  revokedBy    String?              @map("revoked_by") @db.Uuid
  revokeReason SessionRevokeReason? @map("revoke_reason")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([tenantId, isActive])
  @@index([expiresAt])
  @@map("user_sessions")
}

enum DeviceType {
  DESKTOP_APP
  WEB_BROWSER
  MOBILE_APP
  API_CLIENT
}

enum SessionRevokeReason {
  USER_LOGOUT
  ADMIN_REVOKE
  PASSWORD_CHANGED
  SUSPICIOUS_ACTIVITY
  SESSION_LIMIT
  ACCOUNT_SUSPENDED
  ACCOUNT_ANONYMIZED
}

// ═══════════════════════════════════════════════════════════════
// API KEYS
// ═══════════════════════════════════════════════════════════════

model ApiKey {
  id         String     @id @default(cuid())
  userId     String     @db.Uuid
  keyHash    String     @unique
  keyPrefix  String
  name       String
  type       ApiKeyType
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isRevoked  Boolean    @default(false)
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
}

enum ApiKeyType {
  LIVE
  TEST
}

// ═══════════════════════════════════════════════════════════════
// PROVIDER KEYS (BYOK)
// ═══════════════════════════════════════════════════════════════

model ProviderKey {
  id              String    @id @default(cuid())
  userId          String    @db.Uuid
  provider        String
  encryptedKey    String
  iv              String
  status          String    @default("unconfigured")
  lastValidatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// AGENTS
// ═══════════════════════════════════════════════════════════════

model Agent {
  id             String   @id @default(cuid())
  userId         String   @db.Uuid
  name           String
  description    String?
  systemPrompt   String   @db.Text
  model          String   @default("gemini-flash")
  welcomeMessage String?  @db.Text
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]
  channels  Channel[]

  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// KNOWLEDGE BASE
// ═══════════════════════════════════════════════════════════════

model Document {
  id           String         @id @default(cuid())
  agentId      String
  userId       String         @db.Uuid
  filename     String
  originalName String
  fileType     String
  fileSize     Int
  fileUrl      String
  status       DocumentStatus @default(UPLOADING)
  totalChunks  Int            @default(0)
  errorMsg     String?
  createdAt    DateTime       @default(now())

  agent  Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks DocumentChunk[]

  @@index([agentId])
  @@index([userId])
}

enum DocumentStatus {
  UPLOADING
  EXTRACTING
  EMBEDDING
  INDEXED
  ERROR
}

model DocumentChunk {
  id         String                      @id @default(cuid())
  documentId String
  chunkIndex Int
  content    String                      @db.Text
  embedding  Unsupported("vector(768)")?
  tokenCount Int                         @default(0)
  createdAt  DateTime                    @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// ═══════════════════════════════════════════════════════════════
// CHANNELS (OpenClaw)
// ═══════════════════════════════════════════════════════════════

model Channel {
  id                    String        @id @default(cuid())
  userId                String        @db.Uuid
  agentId               String
  platform              Platform
  status                ChannelStatus @default(PENDING)
  displayName           String
  platformConfig        Json
  welcomeMessage        String?       @db.Text
  modelOverride         String?
  businessHoursStart    String?
  businessHoursEnd      String?
  businessHoursTimezone String        @default("America/Sao_Paulo")
  respondOutsideHours   Boolean       @default(true)
  outsideHoursMessage   String?       @db.Text
  isActive              Boolean       @default(true)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent         Agent                 @relation(fields: [agentId], references: [id])
  conversations ChannelConversation[]

  @@unique([userId, platform, displayName])
  @@index([userId])
  @@index([platform, status])
}

enum Platform {
  WHATSAPP
  TELEGRAM
  DISCORD
  SLACK
}

enum ChannelStatus {
  PENDING
  CONNECTING
  ACTIVE
  DISCONNECTED
  ERROR
}

model ChannelConversation {
  id               String   @id @default(cuid())
  channelId        String
  externalUserId   String
  externalUserName String?
  startedAt        DateTime @default(now())
  lastMessageAt    DateTime @default(now())
  messageCount     Int      @default(0)
  isActive         Boolean  @default(true)

  channel  Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages ChannelMessage[]

  @@unique([channelId, externalUserId])
  @@index([channelId, lastMessageAt])
}

model ChannelMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  imageUrl       String?
  modelUsed      String?
  tokensIn       Int?
  tokensOut      Int?
  latencyMs      Int?
  createdAt      DateTime    @default(now())

  conversation ChannelConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ═══════════════════════════════════════════════════════════════
// CONVERSATIONS — Container de interacoes
// Uma conversa = um contexto continuo de troca de mensagens
// Suporta: ai_chat, floating, internal_note e tipos futuros
// ═══════════════════════════════════════════════════════════════

model Conversation {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // Tipo da conversa
  type ConversationType

  // Identificacao
  title String? @db.VarChar(300)
  slug  String? @db.VarChar(100)

  // Vinculo contextual (ticket, KB article, etc.)
  context Json @default("{}")

  // Configuracoes da conversa (provider, model, temperature, etc.)
  settings Json @default("{}")

  // Estado
  status ConversationStatus @default(ACTIVE)

  // Contadores desnormalizados
  messageCount     Int  @default(0) @map("message_count")
  participantCount Int  @default(0) @map("participant_count")
  unreadCount      Json @default("{}") @map("unread_count")

  // Resumo IA
  aiSummary          String?   @map("ai_summary") @db.Text
  aiSummaryUpdatedAt DateTime? @map("ai_summary_updated_at")

  // Custos acumulados
  totalAiTokensIn  Int     @default(0) @map("total_ai_tokens_in")
  totalAiTokensOut Int     @default(0) @map("total_ai_tokens_out")
  totalAiCostUsd   Decimal @default(0) @map("total_ai_cost_usd") @db.Decimal(10, 6)
  totalAiMessages  Int     @default(0) @map("total_ai_messages")

  // Primeiro e ultimo
  firstMessageAt     DateTime? @map("first_message_at")
  lastMessageAt      DateTime? @map("last_message_at")
  lastMessagePreview String?   @map("last_message_preview") @db.VarChar(200)

  // Criacao
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  creator           User                      @relation("ConversationCreator", fields: [createdBy], references: [id])
  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  participants      ConversationParticipant[]
  messages          Message[]
  tagLinks          ConversationTagLink[]
  templateUsageLogs TemplateUsageLog[]

  @@index([tenantId, status, lastMessageAt(sort: Desc)])
  @@index([tenantId, type, status])
  @@index([createdBy, status])
  @@map("conversations")
}

enum ConversationType {
  AI_CHAT
  FLOATING
  INTERNAL_NOTE
  SUPPORT_CHAT
  BOT_FLOW
  VOICE_TRANSCRIPT
  GROUP_CHAT
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  CLOSED
  DELETED
}

// ═══════════════════════════════════════════════════════════════
// CONVERSATION_PARTICIPANTS — Quem participa de cada conversa
// Separada para: N participantes, join/leave, roles, notificacoes
// ═══════════════════════════════════════════════════════════════

model ConversationParticipant {
  id             String @id @default(uuid()) @db.Uuid
  conversationId String @map("conversation_id") @db.Uuid
  userId         String @map("user_id") @db.Uuid

  // Role na conversa
  role ParticipantRole @default(PARTICIPANT)

  // Estado
  status ParticipantStatus @default(ACTIVE)

  // Leitura
  lastReadAt        DateTime? @map("last_read_at")
  lastReadMessageId String?   @map("last_read_message_id") @db.Uuid

  // Preferencias por conversa
  isPinned          Boolean           @default(false) @map("is_pinned")
  isMuted           Boolean           @default(false) @map("is_muted")
  notificationLevel NotificationLevel @default(ALL) @map("notification_level")

  // Timestamps
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId, status])
  @@index([userId, status])
  @@index([userId, isPinned(sort: Desc), conversationId])
  @@map("conversation_participants")
}

enum ParticipantRole {
  CREATOR
  PARTICIPANT
  OBSERVER
  MENTIONED
}

enum ParticipantStatus {
  ACTIVE            @map("ACTIVE")
  LEFT              @map("LEFT")
  REMOVED           @map("REMOVED")
  PARTICIPANT_MUTED @map("MUTED")
}

enum NotificationLevel {
  ALL
  MENTIONS
  NONE
}

// ═══════════════════════════════════════════════════════════════
// MESSAGES — Conteudo de cada turno da conversa
// Threading opcional via parentMessageId
// ═══════════════════════════════════════════════════════════════

model Message {
  id             String @id @default(uuid()) @db.Uuid
  conversationId String @map("conversation_id") @db.Uuid
  tenantId       String @map("tenant_id") @db.Uuid

  // Autor
  senderType SenderType @map("sender_type")
  senderId   String?    @map("sender_id") @db.Uuid

  // Conteudo
  contentType   MessageContentType @default(TEXT) @map("content_type")
  content       String?            @db.Text
  contentBlocks Json?              @map("content_blocks")

  // Threading
  parentMessageId    String? @map("parent_message_id") @db.Uuid
  threadDepth        Int     @default(0) @map("thread_depth")
  threadMessageCount Int     @default(0) @map("thread_message_count")

  // Mencoes
  mentions Json?

  // Estado
  status          MessageStatus @default(SENT)
  editedAt        DateTime?     @map("edited_at")
  editedBy        String?       @map("edited_by") @db.Uuid
  originalContent String?       @map("original_content") @db.Text
  deletedAt       DateTime?     @map("deleted_at")
  deletedBy       String?       @map("deleted_by") @db.Uuid

  // Flags
  isAiGenerated Boolean @default(false) @map("is_ai_generated")
  isPinned      Boolean @default(false) @map("is_pinned")

  // Ordenacao
  sequenceNumber BigInt @map("sequence_number")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  conversation      Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender            User?               @relation("MessageSender", fields: [senderId], references: [id])
  parentMessage     Message?            @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull)
  childMessages     Message[]           @relation("MessageThread")
  aiMetadata        MessageAiMetadata?
  sources           MessageSource[]
  feedback          MessageFeedback[]
  attachments       MessageAttachment[]
  templateUsageLogs TemplateUsageLog[]

  @@index([conversationId, sequenceNumber])
  @@index([conversationId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([senderId, createdAt(sort: Desc)])
  @@index([parentMessageId])
  @@index([conversationId, isAiGenerated])
  @@index([conversationId, isPinned])
  @@map("messages")
}

enum SenderType {
  USER_SENDER   @map("user")
  AI_SENDER     @map("ai")
  SYSTEM_SENDER @map("system")
  BOT_SENDER    @map("bot")
}

enum MessageContentType {
  TEXT
  RICH_TEXT
  CODE
  IMAGE
  FILE
  AUDIO
  SYSTEM_EVENT
  SUGGESTION
  TEMPLATE
  COMPOSITE
}

enum MessageStatus {
  SENDING
  SENT
  DELIVERED
  READ
  EDITED
  MSG_DELETED @map("DELETED")
  FAILED
  STREAMING
}

// ═══════════════════════════════════════════════════════════════
// MESSAGE_AI_METADATA — Metadados de IA por mensagem
// 1:1 com messages (apenas para mensagens de IA)
// Rastreia: provider, modelo, tokens, custo, latencia, cache
// ═══════════════════════════════════════════════════════════════

model MessageAiMetadata {
  id             String @id @default(uuid()) @db.Uuid
  messageId      String @unique @map("message_id") @db.Uuid
  conversationId String @map("conversation_id") @db.Uuid
  tenantId       String @map("tenant_id") @db.Uuid

  // Provider
  provider     String  @db.VarChar(50)
  model        String  @db.VarChar(100)
  modelVersion String? @map("model_version") @db.VarChar(50)

  // Tokens
  tokensInput  Int @default(0) @map("tokens_input")
  tokensOutput Int @default(0) @map("tokens_output")
  tokensCached Int @default(0) @map("tokens_cached")

  // Custo
  costInputUsd  Decimal @default(0) @map("cost_input_usd") @db.Decimal(10, 8)
  costOutputUsd Decimal @default(0) @map("cost_output_usd") @db.Decimal(10, 8)

  // Performance
  latencyMs          Int      @default(0) @map("latency_ms")
  timeToFirstTokenMs Int?     @map("time_to_first_token_ms")
  tokensPerSecond    Decimal? @map("tokens_per_second") @db.Decimal(8, 2)

  // Contexto do prompt
  systemPromptHash          String?  @map("system_prompt_hash") @db.VarChar(64)
  systemPromptTokens        Int?     @map("system_prompt_tokens")
  conversationHistoryTokens Int?     @map("conversation_history_tokens")
  contextWindowUsage        Decimal? @map("context_window_usage") @db.Decimal(5, 2)

  // Streaming
  wasStreamed       Boolean @default(false) @map("was_streamed")
  streamChunks      Int?    @map("stream_chunks")
  streamInterrupted Boolean @default(false) @map("stream_interrupted")

  // Fallback
  wasFallback      Boolean @default(false) @map("was_fallback")
  originalProvider String? @map("original_provider") @db.VarChar(50)
  originalModel    String? @map("original_model") @db.VarChar(100)
  fallbackReason   String? @map("fallback_reason") @db.VarChar(50)

  // Cache
  cacheHit Boolean @default(false) @map("cache_hit")
  cacheKey String? @map("cache_key") @db.VarChar(255)

  // Moderacao
  contentFiltered Boolean @default(false) @map("content_filtered")
  filterReason    String? @map("filter_reason") @db.Text

  // Extras
  rawResponseId String? @map("raw_response_id") @db.VarChar(255)
  metadata      Json    @default("{}")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([provider, model, createdAt(sort: Desc)])
  @@index([wasFallback])
  @@map("message_ai_metadata")
}

// ═══════════════════════════════════════════════════════════════
// MESSAGE_SOURCES — Fontes usadas pela IA para gerar resposta
// N:1 com messages (uma mensagem pode ter multiplas fontes)
// ═══════════════════════════════════════════════════════════════

model MessageSource {
  id             String @id @default(uuid()) @db.Uuid
  messageId      String @map("message_id") @db.Uuid
  conversationId String @map("conversation_id") @db.Uuid
  tenantId       String @map("tenant_id") @db.Uuid

  // Tipo da fonte
  sourceType SourceType @map("source_type")

  // Referencia
  referenceId    String? @map("reference_id") @db.Uuid
  referenceUrl   String? @map("reference_url") @db.VarChar(2000)
  referenceTitle String? @map("reference_title") @db.VarChar(500)

  // Relevancia
  relevanceScore Decimal? @map("relevance_score") @db.Decimal(5, 4)
  relevanceRank  Int?     @map("relevance_rank")

  // Trecho
  excerpt String? @db.Text

  // Uso
  wasCited     Boolean @default(false) @map("was_cited")
  citationText String? @map("citation_text") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([conversationId])
  @@index([sourceType, referenceId])
  @@map("message_sources")
}

enum SourceType {
  KB_ARTICLE
  KB_SEARCH
  WEB_SEARCH
  WEB_PAGE
  TICKET_HISTORY
  CONVERSATION_REF @map("CONVERSATION")
  UPLOADED_FILE
  SCREEN_CAPTURE
  AUDIO_TRANSCRIPT
  AI_KNOWLEDGE
  TEMPLATE_SOURCE  @map("TEMPLATE")
  API_RESPONSE
  DATABASE_QUERY
}

// ═══════════════════════════════════════════════════════════════
// MESSAGE_FEEDBACK — Avaliacao humana de mensagens de IA
// 1:1 por (message_id, user_id)
// ═══════════════════════════════════════════════════════════════

model MessageFeedback {
  id             String @id @default(uuid()) @db.Uuid
  messageId      String @map("message_id") @db.Uuid
  conversationId String @map("conversation_id") @db.Uuid
  tenantId       String @map("tenant_id") @db.Uuid
  userId         String @map("user_id") @db.Uuid

  // Avaliacao
  rating FeedbackRating

  // Detalhes
  comment String? @db.Text
  tags    Json?

  // Acao tomada
  actionTaken String? @map("action_taken") @db.VarChar(30)

  // Correcao
  correctedContent String? @map("corrected_content") @db.Text

  // Contexto do feedback
  feedbackContext Json? @map("feedback_context")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([conversationId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, rating, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("message_feedback")
}

enum FeedbackRating {
  POSITIVE
  NEGATIVE
  MIXED
}

// ═══════════════════════════════════════════════════════════════
// MESSAGE_ATTACHMENTS — Arquivos vinculados a mensagens
// N:1 com messages (uma mensagem pode ter multiplos anexos)
// ═══════════════════════════════════════════════════════════════

model MessageAttachment {
  id             String @id @default(uuid()) @db.Uuid
  messageId      String @map("message_id") @db.Uuid
  conversationId String @map("conversation_id") @db.Uuid
  tenantId       String @map("tenant_id") @db.Uuid

  // Arquivo
  fileName      String @map("file_name") @db.VarChar(255)
  fileType      String @map("file_type") @db.VarChar(100)
  fileSizeBytes BigInt @map("file_size_bytes")
  filePath      String @map("file_path") @db.VarChar(500)

  // Thumbnail
  thumbnailPath String? @map("thumbnail_path") @db.VarChar(500)

  // Categorizacao
  category AttachmentCategory @default(GENERIC_FILE)

  // Processamento
  processingStatus AttachmentProcessingStatus @default(UPLOADED) @map("processing_status")
  processingResult Json?                      @map("processing_result")

  // Expiracao
  expiresAt DateTime? @map("expires_at")

  // Metadados
  metadata Json @default("{}")

  uploadedBy String   @map("uploaded_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  message  Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploader User    @relation("AttachmentUploader", fields: [uploadedBy], references: [id])

  @@index([messageId])
  @@index([conversationId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([category, tenantId])
  @@map("message_attachments")
}

enum AttachmentCategory {
  IMAGE_FILE   @map("IMAGE")
  SCREENSHOT
  DOCUMENT
  AUDIO_FILE   @map("AUDIO")
  VIDEO_FILE   @map("VIDEO")
  LOG_FILE
  CODE_FILE    @map("CODE")
  GENERIC_FILE @map("FILE")
}

enum AttachmentProcessingStatus {
  UPLOADED
  PROCESSING
  COMPLETED
  PROC_FAILED @map("FAILED")
}

// ═══════════════════════════════════════════════════════════════
// CONVERSATION_TAGS — Etiquetas para organizar conversas
// ═══════════════════════════════════════════════════════════════

model ConversationTag {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  name        String  @db.VarChar(50)
  color       String  @default("#3f3f46") @db.VarChar(7)
  description String? @db.VarChar(200)
  usageCount  Int     @default(0) @map("usage_count")
  createdBy   String  @map("created_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant  Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User                  @relation("TagCreator", fields: [createdBy], references: [id])
  links   ConversationTagLink[]

  @@unique([tenantId, name])
  @@map("conversation_tags")
}

model ConversationTagLink {
  conversationId String   @map("conversation_id") @db.Uuid
  tagId          String   @map("tag_id") @db.Uuid
  addedBy        String   @map("added_by") @db.Uuid
  addedAt        DateTime @default(now()) @map("added_at")

  // Relations
  conversation Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag          ConversationTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  user         User            @relation("TagLinkUser", fields: [addedBy], references: [id])

  @@id([conversationId, tagId])
  @@index([conversationId])
  @@index([tagId])
  @@map("conversation_tag_links")
}

// ═══════════════════════════════════════════════════════════════
// USAGE & BILLING
// ═══════════════════════════════════════════════════════════════

model UsageCounter {
  id           String @id @default(cuid())
  userId       String @db.Uuid
  period       String
  messages     Int    @default(0)
  tokensIn     Int    @default(0)
  tokensOut    Int    @default(0)
  byokMessages Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId, period])
}

// ═══════════════════════════════════════════════════════════════
// OUTGOING WEBHOOKS
// ═══════════════════════════════════════════════════════════════

model WebhookEndpoint {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  url       String
  secret    String
  events    String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs WebhookLog[]

  @@index([userId])
}

model WebhookLog {
  id           String    @id @default(cuid())
  endpointId   String
  event        String
  payload      Json
  statusCode   Int?
  responseBody String?   @db.Text
  deliveredAt  DateTime?
  createdAt    DateTime  @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, createdAt])
}

// ═══════════════════════════════════════════════════════════════
// KB ARTICLES (Structured Knowledge Base)
// ═══════════════════════════════════════════════════════════════

model KbCategory {
  id          String   @id @default(cuid())
  userId      String   @db.Uuid
  name        String
  slug        String
  description String?
  parentId    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   KbCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children KbCategory[] @relation("CategoryHierarchy")
  articles KbArticle[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([parentId])
}

model KbArticle {
  id              String           @id @default(cuid())
  userId          String           @db.Uuid
  categoryId      String?
  title           String
  slug            String
  summary         String?          @db.Text
  content         String           @db.Text
  status          KbArticleStatus  @default(DRAFT)
  difficulty      KbDifficulty     @default(BASIC)
  targetAudience  KbAudience       @default(TECHNICIAN)
  tags            String[]
  viewCount       Int              @default(0)
  helpfulCount    Int              @default(0)
  notHelpfulCount Int              @default(0)
  insertionMode   KbInsertionMode?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      KbCategory?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  attachments   KbArticleAttachment[]
  insertionLogs KbInsertionLog[]

  @@unique([userId, slug])
  @@index([userId, status])
  @@index([userId, categoryId])
  @@index([createdAt])
}

enum KbArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum KbDifficulty {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum KbAudience {
  END_USER
  TECHNICIAN
  ADMIN
}

enum KbInsertionMode {
  QUICK_ADD
  FILE_UPLOAD
  FULL_FORM
  FROM_CHAT
}

model KbArticleAttachment {
  id               String   @id @default(cuid())
  userId           String   @db.Uuid
  articleId        String
  fileName         String
  fileType         String
  fileSizeBytes    Int
  filePath         String
  extractedText    String?  @db.Text
  extractionMethod String?
  extractionStatus String   @default("pending")
  extractionError  String?
  pageCount        Int?
  wordCount        Int?
  isSourceFile     Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  article KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([userId])
}

model KbInsertionLog {
  id               String          @id @default(cuid())
  userId           String          @db.Uuid
  articleId        String?
  insertionMode    KbInsertionMode
  originalInput    Json?
  aiProvider       String?
  aiModel          String?
  aiSuggestions    Json?
  aiTokensUsed     Int?
  aiCostUsd        Float?
  aiLatencyMs      Int?
  fieldsAutoFilled Int             @default(0)
  fieldsUserEdited Int             @default(0)
  userEdits        Json?
  status           String          @default("completed")
  createdAt        DateTime        @default(now())

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  article KbArticle? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([insertionMode, createdAt])
}

// ═══════════════════════════════════════════════════════════════
// SLA_POLICIES — Definicoes de SLA por tenant
// Cada tenant define seus tempos de resposta por prioridade
// ═══════════════════════════════════════════════════════════════

model SlaPolicy {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  name      String  @db.VarChar(100)
  isDefault Boolean @default(false) @map("is_default")

  // Tempos por prioridade (em minutos, JSONB)
  // { "critical": { "first_response": 60, "resolution": 240 }, ... }
  targets Json

  // Horario de atendimento (JSONB)
  // { "timezone": "America/Sao_Paulo", "schedule": { ... }, "holidays": [...] }
  businessHours Json @default("{\"timezone\":\"America/Sao_Paulo\",\"schedule\":{\"monday\":{\"start\":\"08:00\",\"end\":\"18:00\"},\"tuesday\":{\"start\":\"08:00\",\"end\":\"18:00\"},\"wednesday\":{\"start\":\"08:00\",\"end\":\"18:00\"},\"thursday\":{\"start\":\"08:00\",\"end\":\"18:00\"},\"friday\":{\"start\":\"08:00\",\"end\":\"18:00\"},\"saturday\":null,\"sunday\":null},\"holidays\":[]}") @map("business_hours")

  // Alertas
  warningThresholdPct Int @default(75) @map("warning_threshold_pct")

  status String @default("active") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticketSlas TicketSla[]

  @@index([tenantId, isDefault])
  @@map("sla_policies")
}

// ═══════════════════════════════════════════════════════════════
// TICKET_SLA — Tracking de SLA por ticket externo
// Calcula tempos baseado nos timestamps do cache
// Teki pode calcular SLA mesmo que o sistema externo nao tenha
// ═══════════════════════════════════════════════════════════════

model TicketSla {
  id               String @id @default(uuid()) @db.Uuid
  connectorId      String @map("connector_id") @db.Uuid
  externalTicketId String @map("external_ticket_id") @db.VarChar(255)
  slaPolicyId      String @map("sla_policy_id") @db.Uuid
  tenantId         String @map("tenant_id") @db.Uuid

  // First response
  firstResponseTargetAt      DateTime? @map("first_response_target_at")
  firstResponseActualAt      DateTime? @map("first_response_actual_at")
  firstResponseBreached      Boolean   @default(false) @map("first_response_breached")
  firstResponseBreachMinutes Int?      @map("first_response_breach_minutes")

  // Resolution
  resolutionTargetAt      DateTime? @map("resolution_target_at")
  resolutionActualAt      DateTime? @map("resolution_actual_at")
  resolutionBreached      Boolean   @default(false) @map("resolution_breached")
  resolutionBreachMinutes Int?      @map("resolution_breach_minutes")

  // Clock
  clockStatus        SlaClockStatus @default(RUNNING) @map("clock_status")
  totalPausedMinutes Int            @default(0) @map("total_paused_minutes")
  lastPausedAt       DateTime?      @map("last_paused_at")
  lastResumedAt      DateTime?      @map("last_resumed_at")

  // Warning
  firstResponseWarningSent Boolean @default(false) @map("first_response_warning_sent")
  resolutionWarningSent    Boolean @default(false) @map("resolution_warning_sent")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  connector ExternalConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  slaPolicy SlaPolicy         @relation(fields: [slaPolicyId], references: [id])

  @@unique([connectorId, externalTicketId])
  @@index([tenantId, firstResponseBreached, resolutionBreached])
  @@index([firstResponseTargetAt, resolutionTargetAt])
  @@map("ticket_sla")
}

enum SlaClockStatus {
  RUNNING
  PAUSED
  STOPPED
}

// ═══════════════════════════════════════════════════════════════
// NOTIFICATIONS — Fila central de notificacoes
// Cada notificacao e um evento entregue por multiplos canais
// ═══════════════════════════════════════════════════════════════

model Notification {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // Destinatario
  recipientId String @map("recipient_id") @db.Uuid

  // Tipo (extensivel: ticket_created, ticket_assigned, ticket_status_changed,
  // ticket_resolved, ticket_reopened, ticket_escalated, ticket_sla_warning,
  // ticket_sla_breached, new_message, mention, reply_to_thread,
  // ai_suggestion, ai_error, ai_cost_warning, kb_article_published,
  // kb_suggestion_from_chat, team_member_joined, team_member_removed,
  // role_changed, plan_limit_warning, plan_limit_reached, plan_upgraded,
  // plan_expiring, login_new_device, password_changed, suspicious_activity,
  // system_maintenance, system_update)
  type String @db.VarChar(50)

  // Conteudo
  title   String  @db.VarChar(200)
  body    String? @db.Text
  summary String? @db.VarChar(500)

  // Referencia
  resourceType String? @map("resource_type") @db.VarChar(30)
  resourceId   String? @map("resource_id") @db.Uuid
  actionUrl    String? @map("action_url") @db.VarChar(500)

  // Ator
  actorId        String? @map("actor_id") @db.Uuid
  actorName      String? @map("actor_name") @db.VarChar(200)
  actorAvatarUrl String? @map("actor_avatar_url") @db.VarChar(500)

  // Prioridade
  priority NotificationPriority @default(NORMAL)

  // Agrupamento
  groupKey   String? @map("group_key") @db.VarChar(200)
  groupCount Int     @default(1) @map("group_count")

  // Canais de entrega (JSONB com status por canal)
  channels Json @default("{\"in_app\":{\"status\":\"pending\"},\"email\":{\"status\":\"pending\"},\"desktop\":{\"status\":\"pending\"},\"websocket\":{\"status\":\"pending\"}}")

  // Estado
  isRead     Boolean   @default(false) @map("is_read")
  readAt     DateTime? @map("read_at")
  isArchived Boolean   @default(false) @map("is_archived")
  archivedAt DateTime? @map("archived_at")

  // Expiracao
  expiresAt DateTime? @map("expires_at")

  // Metadata extensivel (JSONB com dados extras por tipo)
  data Json @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipient User   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User?  @relation("NotificationActor", fields: [actorId], references: [id])

  @@index([recipientId, isRead, createdAt(sort: Desc)])
  @@index([recipientId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([recipientId, type, createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@index([recipientId, groupKey, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("notifications")
}

enum NotificationPriority {
  URGENT
  HIGH
  NORMAL
  LOW
}

// ═══════════════════════════════════════════════════════════════
// NOTIFICATION_PREFERENCES_OVERRIDE — Override por tipo
// Mais granular que user_preferences.notification_settings
// ═══════════════════════════════════════════════════════════════

model NotificationPreferencesOverride {
  id       String @id @default(uuid()) @db.Uuid
  userId   String @map("user_id") @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  notificationType String @map("notification_type") @db.VarChar(50)

  // Override por canal (NULL = usar padrao do user_preferences)
  inAppEnabled     Boolean? @map("in_app_enabled")
  emailEnabled     Boolean? @map("email_enabled")
  desktopEnabled   Boolean? @map("desktop_enabled")
  websocketEnabled Boolean? @map("websocket_enabled")

  // Digest
  emailDigest String? @map("email_digest") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, notificationType])
  @@index([userId, tenantId])
  @@map("notification_preferences_override")
}

// ═══════════════════════════════════════════════════════════════
// AI_PROVIDER_CONFIGS — Configuracao de providers de IA por tenant
// Cada tenant tem N providers com suas API keys e preferencias
// ═══════════════════════════════════════════════════════════════

model AiProviderConfig {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // Provider
  provider    String  @db.VarChar(50)
  displayName String? @map("display_name") @db.VarChar(100)

  // Credenciais (criptografadas AES-256-GCM)
  apiKeyEncrypted       String    @map("api_key_encrypted") @db.VarChar(1000)
  apiKeyPrefix          String?   @map("api_key_prefix") @db.VarChar(10)
  apiKeyAddedAt         DateTime  @default(now()) @map("api_key_added_at")
  apiKeyLastValidatedAt DateTime? @map("api_key_last_validated_at")
  apiKeyValid           Boolean   @default(true) @map("api_key_valid")

  // Modelo preferido
  defaultModel    String @map("default_model") @db.VarChar(100)
  availableModels Json   @default("[]") @map("available_models")

  // Configuracoes (JSONB: temperature, max_tokens, timeout, etc.)
  settings Json @default("{}")

  // Estado
  isActive      Boolean @default(true) @map("is_active")
  priorityOrder Int     @default(0) @map("priority_order")
  isFallback    Boolean @default(false) @map("is_fallback")

  // Limites
  monthlyCostLimitUsd Decimal? @map("monthly_cost_limit_usd") @db.Decimal(10, 2)
  dailyRequestLimit   Int?     @map("daily_request_limit")
  rateLimitRpm        Int?     @map("rate_limit_rpm")

  // Contadores do mes atual
  currentMonthCostUsd   Decimal  @default(0) @map("current_month_cost_usd") @db.Decimal(10, 4)
  currentMonthRequests  Int      @default(0) @map("current_month_requests")
  currentMonthTokensIn  Int      @default(0) @map("current_month_tokens_in")
  currentMonthTokensOut Int      @default(0) @map("current_month_tokens_out")
  currentMonthResetAt   DateTime @default(now()) @map("current_month_reset_at")

  // Metadata
  configuredBy String @map("configured_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  configurator User   @relation("AiConfigConfigurator", fields: [configuredBy], references: [id])

  @@unique([tenantId, provider])
  @@unique([tenantId, priorityOrder])
  @@index([tenantId, isActive, priorityOrder])
  @@map("ai_provider_configs")
}

// ═══════════════════════════════════════════════════════════════
// AI_USAGE_DAILY — Uso diario de IA por tenant/provider
// Agregado por dia para queries rapidas e analytics
// ═══════════════════════════════════════════════════════════════

model AiUsageDaily {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  provider  String   @db.VarChar(50)
  model     String   @db.VarChar(100)
  usageDate DateTime @map("usage_date") @db.Date

  // Contadores
  requestCount Int     @default(0) @map("request_count")
  tokensInput  Int     @default(0) @map("tokens_input")
  tokensOutput Int     @default(0) @map("tokens_output")
  tokensCached Int     @default(0) @map("tokens_cached")
  costUsd      Decimal @default(0) @map("cost_usd") @db.Decimal(10, 6)

  // Performance
  avgLatencyMs  Int? @map("avg_latency_ms")
  p95LatencyMs  Int? @map("p95_latency_ms")
  errorCount    Int  @default(0) @map("error_count")
  fallbackCount Int  @default(0) @map("fallback_count")
  timeoutCount  Int  @default(0) @map("timeout_count")

  // Feedback
  feedbackPositive Int @default(0) @map("feedback_positive")
  feedbackNegative Int @default(0) @map("feedback_negative")

  // Breakdown por tipo de uso (JSONB)
  usageBreakdown Json @default("{}") @map("usage_breakdown")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider, model, usageDate])
  @@index([tenantId, usageDate(sort: Desc)])
  @@index([provider, model, usageDate(sort: Desc)])
  @@map("ai_usage_daily")
}

// ═══════════════════════════════════════════════════════════════
// AI_ROUTING_RULES — Regras de roteamento de IA por tenant
// Como o ProviderRouter decide qual provider usar
// ═══════════════════════════════════════════════════════════════

model AiRoutingRules {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @unique @map("tenant_id") @db.Uuid

  // Estrategia
  strategy RoutingStrategy @default(PRIORITY)

  // Fallback
  fallbackEnabled     Boolean @default(true) @map("fallback_enabled")
  maxFallbackAttempts Int     @default(2) @map("max_fallback_attempts")
  fallbackOn          Json    @default("[\"rate_limit\",\"timeout\",\"error_500\"]") @map("fallback_on")

  // Limites globais
  monthlyBudgetUsd        Decimal? @map("monthly_budget_usd") @db.Decimal(10, 2)
  budgetAlertThresholdPct Int      @default(80) @map("budget_alert_threshold_pct")
  budgetHardStop          Boolean  @default(false) @map("budget_hard_stop")

  // Regras por tipo de uso (JSONB override de provider por tipo)
  typeRules Json @default("{}") @map("type_rules")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ai_routing_rules")
}

enum RoutingStrategy {
  PRIORITY
  ROUND_ROBIN
  COST_OPTIMIZED
  LATENCY_OPTIMIZED
}

// ═══════════════════════════════════════════════════════════════
// RESPONSE_TEMPLATES — Respostas prontas reutilizaveis
// Inseridas em conversas, notas internas, resolucoes de tickets
// ═══════════════════════════════════════════════════════════════

model ResponseTemplate {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // Identificacao
  title       String  @db.VarChar(200)
  slug        String? @db.VarChar(200)
  description String? @db.Text

  // Conteudo (Markdown com variaveis: "Ola {{requester_name}}, ...")
  content     String  @db.Text
  contentHtml String? @map("content_html") @db.Text

  // Variaveis disponiveis (JSONB)
  variables Json @default("[]")

  // Classificacao
  category String? @db.VarChar(100)
  tags     Json    @default("[]")

  // Escopo
  scope        TemplateScope @default(TEAM)
  applicableTo Json          @default("[\"conversation\",\"ticket_resolution\",\"internal_note\"]") @map("applicable_to")

  // Atalho (ex: "/reinicio", "/saudacao")
  shortcut String? @db.VarChar(50)

  // Estado
  status  TemplateStatus @default(ACTIVE)
  version Int            @default(1)

  // Metricas
  usageCount       Int       @default(0) @map("usage_count")
  lastUsedAt       DateTime? @map("last_used_at")
  lastUsedBy       String?   @map("last_used_by") @db.Uuid
  avgFeedbackScore Decimal?  @map("avg_feedback_score") @db.Decimal(3, 2)

  // IA
  aiGenerated Boolean @default(false) @map("ai_generated")
  aiImproved  Boolean @default(false) @map("ai_improved")

  // Metadata
  createdBy String  @map("created_by") @db.Uuid
  updatedBy String? @map("updated_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator   User               @relation("TemplateCreator", fields: [createdBy], references: [id])
  updater   User?              @relation("TemplateUpdater", fields: [updatedBy], references: [id])
  lastUser  User?              @relation("TemplateLastUser", fields: [lastUsedBy], references: [id])
  usageLogs TemplateUsageLog[]

  @@unique([tenantId, shortcut])
  @@index([tenantId, status, category])
  @@index([tenantId, scope, status])
  @@index([tenantId, shortcut])
  @@index([tenantId, usageCount(sort: Desc)])
  @@map("response_templates")
}

enum TemplateScope {
  PERSONAL
  TEAM
  PUBLIC
}

enum TemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// ═══════════════════════════════════════════════════════════════
// TEMPLATE_USAGE_LOG — Registro de cada uso de template
// Para analytics: quais templates sao usados, onde, resultado
// ═══════════════════════════════════════════════════════════════

model TemplateUsageLog {
  id         String @id @default(uuid()) @db.Uuid
  templateId String @map("template_id") @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  userId     String @map("user_id") @db.Uuid

  // Contexto de uso
  usedIn           String  @map("used_in") @db.VarChar(30)
  conversationId   String? @map("conversation_id") @db.Uuid
  messageId        String? @map("message_id") @db.Uuid
  externalTicketId String? @map("external_ticket_id") @db.VarChar(255)

  // Modificacao
  wasModified     Boolean  @default(false) @map("was_modified")
  modificationPct Decimal? @map("modification_pct") @db.Decimal(5, 2)

  // Variaveis
  variablesFilled      Json? @map("variables_filled")
  variablesManualCount Int   @default(0) @map("variables_manual_count")

  templateVersion Int @map("template_version")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  template     ResponseTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id])
  conversation Conversation?    @relation(fields: [conversationId], references: [id])
  message      Message?         @relation(fields: [messageId], references: [id])

  @@index([templateId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("template_usage_log")
}

// ═══════════════════════════════════════════════════════════════
// EXTERNAL_CONNECTORS — Sistemas de chamados conectados
// Cada tenant pode ter 1+ connectors (GLPI, Zendesk, Freshdesk, OTRS)
// O sistema externo e a fonte de verdade dos tickets.
// O Teki NUNCA duplica dados — consulta em tempo real.
// ═══════════════════════════════════════════════════════════════

model ExternalConnector {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // Sistema
  platform    ConnectorPlatform
  displayName String?           @map("display_name") @db.VarChar(100)

  // Conexao
  baseUrl String @map("base_url") @db.VarChar(500)

  // Autenticacao (credenciais criptografadas AES-256-GCM)
  authType                 ConnectorAuthType @map("auth_type")
  authCredentialsEncrypted String            @map("auth_credentials_encrypted") @db.Text

  // Sincronizacao
  syncDirection SyncDirection @default(READ_ONLY) @map("sync_direction")
  syncConfig    Json          @default("{}") @map("sync_config")

  // Webhook (alternativa a polling)
  webhookSecretEncrypted String? @map("webhook_secret_encrypted") @db.VarChar(500)
  webhookUrl             String? @map("webhook_url") @db.VarChar(500)

  // Mapeamento de usuarios
  userMappingStrategy String @default("email") @map("user_mapping_strategy") @db.VarChar(20)

  // Estado
  status ConnectorStatus @default(CONFIGURING)

  lastSyncAt          DateTime? @map("last_sync_at")
  lastSyncStatus      String?   @map("last_sync_status") @db.VarChar(20)
  lastSyncError       String?   @map("last_sync_error") @db.Text
  lastSyncTicketCount Int?      @map("last_sync_ticket_count")

  consecutiveErrors Int @default(0) @map("consecutive_errors")
  errorThreshold    Int @default(5) @map("error_threshold")

  // Health
  healthCheckAt     DateTime?    @map("health_check_at")
  healthStatus      HealthStatus @default(UNKNOWN) @map("health_status")
  avgResponseTimeMs Int?         @map("avg_response_time_ms")

  // Metadata
  platformVersion String? @map("platform_version") @db.VarChar(50)
  capabilities    Json    @default("[]")

  configuredBy String @map("configured_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  configurator User   @relation("ConnectorConfigurator", fields: [configuredBy], references: [id])

  fieldMappings ConnectorFieldMapping[]
  userMappings  ConnectorUserMapping[]
  ticketCaches  TicketCache[]
  annotations   TicketAnnotation[]
  syncLogs      ConnectorSyncLog[]
  ticketSlas    TicketSla[]

  @@index([tenantId, status])
  @@index([platform, status])
  @@map("external_connectors")
}

enum ConnectorPlatform {
  GLPI
  ZENDESK
  FRESHDESK
  OTRS
}

enum ConnectorAuthType {
  API_TOKEN
  BASIC_AUTH
  OAUTH2
  API_KEY_HEADER
}

enum SyncDirection {
  READ_ONLY
  BIDIRECTIONAL
  WRITE_BACK_NOTES
}

enum ConnectorStatus {
  CONFIGURING
  TESTING
  ACTIVE
  PAUSED
  ERROR
  DISCONNECTED
}

enum HealthStatus {
  HEALTHY
  DEGRADED
  DOWN
  UNKNOWN
}

// ═══════════════════════════════════════════════════════════════
// CONNECTOR_FIELD_MAPPINGS — Traducao de campos entre sistemas
// GLPI "urgencia" 5 = Teki "priority" "critical"
// ═══════════════════════════════════════════════════════════════

model ConnectorFieldMapping {
  id          String @id @default(uuid()) @db.Uuid
  connectorId String @map("connector_id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid

  // Campo normalizado do Teki
  tekiField String @map("teki_field") @db.VarChar(50)

  // Campo no sistema externo
  externalField String @map("external_field") @db.VarChar(100)

  // Mapeamento de valores (externo → Teki, JSONB)
  valueMappings   Json  @map("value_mappings")
  reverseMappings Json? @map("reverse_mappings")

  // Transformacao
  transformType   String @default("direct") @map("transform_type") @db.VarChar(20)
  transformConfig Json?  @map("transform_config")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  connector ExternalConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@unique([connectorId, tekiField])
  @@index([connectorId])
  @@map("connector_field_mappings")
}

// ═══════════════════════════════════════════════════════════════
// CONNECTOR_USER_MAPPINGS — Vinculo user Teki <-> user externo
// Preenchido automaticamente por email ou manualmente
// ═══════════════════════════════════════════════════════════════

model ConnectorUserMapping {
  id          String @id @default(uuid()) @db.Uuid
  connectorId String @map("connector_id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid

  tekiUserId        String  @map("teki_user_id") @db.Uuid
  externalUserId    String  @map("external_user_id") @db.VarChar(255)
  externalUserName  String? @map("external_user_name") @db.VarChar(200)
  externalUserEmail String? @map("external_user_email") @db.VarChar(255)

  mappingMethod String  @default("email") @map("mapping_method") @db.VarChar(20)
  isVerified    Boolean @default(false) @map("is_verified")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  connector ExternalConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  tekiUser  User              @relation(fields: [tekiUserId], references: [id], onDelete: Cascade)

  @@unique([connectorId, tekiUserId])
  @@unique([connectorId, externalUserId])
  @@index([connectorId])
  @@index([tekiUserId])
  @@index([connectorId, externalUserId])
  @@map("connector_user_mappings")
}

// ═══════════════════════════════════════════════════════════════
// TICKET_CACHE — Cache efemero de tickets externos
// TTL curto (5-15 min). NAO e fonte de verdade.
// Proposito: contexto rapido para IA, listagem sem latencia,
// busca full-text que o sistema externo nao oferece.
// ═══════════════════════════════════════════════════════════════

model TicketCache {
  id          String @id @default(uuid()) @db.Uuid
  connectorId String @map("connector_id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid

  // Referencia externa
  externalTicketId     String  @map("external_ticket_id") @db.VarChar(255)
  externalTicketNumber String? @map("external_ticket_number") @db.VarChar(50)
  externalUrl          String? @map("external_url") @db.VarChar(500)

  // Dados normalizados (traduzidos via field_mappings)
  title       String? @db.VarChar(500)
  description String? @db.Text
  status      String? @db.VarChar(30)
  priority    String? @db.VarChar(20)
  type        String? @db.VarChar(30)
  category    String? @db.VarChar(100)
  tags        Json    @default("[]")

  // Pessoas
  requesterName   String? @map("requester_name") @db.VarChar(200)
  requesterEmail  String? @map("requester_email") @db.VarChar(255)
  assignedToName  String? @map("assigned_to_name") @db.VarChar(200)
  assignedToEmail String? @map("assigned_to_email") @db.VarChar(255)
  groupName       String? @map("group_name") @db.VarChar(100)

  // Datas do sistema externo
  externalCreatedAt  DateTime? @map("external_created_at")
  externalUpdatedAt  DateTime? @map("external_updated_at")
  externalResolvedAt DateTime? @map("external_resolved_at")
  externalClosedAt   DateTime? @map("external_closed_at")

  // Dados extras
  rawData      Json? @map("raw_data")
  customFields Json  @default("{}") @map("custom_fields")

  // Cache control
  cachedAt    DateTime    @default(now()) @map("cached_at")
  expiresAt   DateTime    @map("expires_at")
  cacheSource CacheSource @default(POLL) @map("cache_source")
  isStale     Boolean     @default(false) @map("is_stale")

  // Relations
  connector ExternalConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@unique([connectorId, externalTicketId])
  @@index([tenantId, status, priority])
  @@index([connectorId, cachedAt(sort: Desc)])
  @@index([expiresAt])
  @@index([connectorId, externalTicketId])
  @@index([assignedToEmail, status])
  @@index([tenantId, status])
  @@map("ticket_cache")
}

enum CacheSource {
  POLL
  WEBHOOK
  ON_DEMAND
  AI_CONTEXT
}

// ═══════════════════════════════════════════════════════════════
// TICKET_ANNOTATIONS — Dados que o Teki adiciona ao ticket
// O sistema externo tem o ticket. O Teki tem a INTELIGENCIA.
// Um annotation por ticket externo por connector.
// ═══════════════════════════════════════════════════════════════

model TicketAnnotation {
  id               String @id @default(uuid()) @db.Uuid
  connectorId      String @map("connector_id") @db.Uuid
  tenantId         String @map("tenant_id") @db.Uuid
  externalTicketId String @map("external_ticket_id") @db.VarChar(255)

  // Sugestoes de IA (JSONB array)
  aiSuggestions Json @default("[]") @map("ai_suggestions")

  // Artigos KB vinculados (JSONB array)
  linkedKbArticles Json @default("[]") @map("linked_kb_articles")

  // Notas internas rapidas do Teki (JSONB array)
  quickNotes Json @default("[]") @map("quick_notes")

  // Tags do Teki (separadas das tags do sistema externo)
  tekiTags Json @default("[]") @map("teki_tags")

  // Classificacao IA
  aiCategorySuggestion String?  @map("ai_category_suggestion") @db.VarChar(100)
  aiCategoryConfidence Decimal? @map("ai_category_confidence") @db.Decimal(5, 4)
  aiPrioritySuggestion String?  @map("ai_priority_suggestion") @db.VarChar(20)
  aiPriorityConfidence Decimal? @map("ai_priority_confidence") @db.Decimal(5, 4)
  aiAutoClassified     Boolean  @default(false) @map("ai_auto_classified")

  // Conversas vinculadas (conversations.context.external_ticket_id)
  conversationCount Int @default(0) @map("conversation_count")

  // Write-back status (JSONB log do que foi enviado ao externo)
  writeBackLog Json @default("[]") @map("write_back_log")

  // Metricas
  firstAiSuggestionAt DateTime? @map("first_ai_suggestion_at")
  totalAiSuggestions  Int       @default(0) @map("total_ai_suggestions")
  totalAiCostUsd      Decimal   @default(0) @map("total_ai_cost_usd") @db.Decimal(10, 6)
  suggestionsAccepted Int       @default(0) @map("suggestions_accepted")
  suggestionsRejected Int       @default(0) @map("suggestions_rejected")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  connector ExternalConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@unique([connectorId, externalTicketId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([connectorId, externalTicketId])
  @@index([tenantId, totalAiSuggestions(sort: Desc)])
  @@map("ticket_annotations")
}

// ═══════════════════════════════════════════════════════════════
// CONNECTOR_SYNC_LOG — Registro de cada sincronizacao
// Para debug, auditoria e analise de performance
// ═══════════════════════════════════════════════════════════════

model ConnectorSyncLog {
  id          String @id @default(uuid()) @db.Uuid
  connectorId String @map("connector_id") @db.Uuid
  tenantId    String @map("tenant_id") @db.Uuid

  // Tipo
  syncType SyncType @map("sync_type")

  // Resultado
  status SyncLogStatus

  ticketsFetched Int @default(0) @map("tickets_fetched")
  ticketsCreated Int @default(0) @map("tickets_created")
  ticketsUpdated Int @default(0) @map("tickets_updated")
  ticketsStale   Int @default(0) @map("tickets_stale")

  // Performance
  durationMs       Int    @map("duration_ms")
  apiCallsMade     Int    @default(0) @map("api_calls_made")
  bytesTransferred BigInt @default(0) @map("bytes_transferred")

  // Erro
  errorMessage String? @map("error_message") @db.Text
  errorDetails Json?   @map("error_details")

  // Write-back
  writeBackCount  Int @default(0) @map("write_back_count")
  writeBackErrors Int @default(0) @map("write_back_errors")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  connector ExternalConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId, createdAt(sort: Desc)])
  @@index([connectorId, status, createdAt(sort: Desc)])
  @@map("connector_sync_log")
}

enum SyncType {
  FULL
  INCREMENTAL
  SINGLE
  SYNC_WEBHOOK @map("WEBHOOK")
  WRITE_BACK
}

enum SyncLogStatus {
  SUCCESS
  PARTIAL
  SYNC_ERROR @map("ERROR")
}
