generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ═══════════════════════════════════════════════════════════════
// USERS & AUTH
// ═══════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  tenantId      String?
  email         String    @unique
  name          String
  passwordHash  String
  avatarUrl     String?
  planId        PlanTier  @default(FREE)
  planExpiresAt DateTime?
  mpPreapprovalId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant           Tenant?  @relation(fields: [tenantId], references: [id])
  agents           Agent[]
  channels         Channel[]
  apiKeys          ApiKey[]
  usageCounters    UsageCounter[]
  conversations    Conversation[]
  providerKeys     ProviderKey[]
  webhookEndpoints WebhookEndpoint[]
  sessions         Session[]
  documents        Document[]
  assignedTickets  Ticket[]          @relation("TicketAttendant")
  resolvedTickets  Ticket[]          @relation("TicketResolver")
  createdKbArticles  KnowledgeBaseArticle[] @relation("KbCreatedBy")
  reviewedKbArticles KnowledgeBaseArticle[] @relation("KbReviewedBy")

  @@index([email])
  @@index([tenantId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

enum PlanTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// ═══════════════════════════════════════════════════════════════
// API KEYS
// ═══════════════════════════════════════════════════════════════

model ApiKey {
  id         String     @id @default(cuid())
  userId     String
  keyHash    String     @unique
  keyPrefix  String
  name       String
  type       ApiKeyType
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isRevoked  Boolean    @default(false)
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
}

enum ApiKeyType {
  LIVE
  TEST
}

// ═══════════════════════════════════════════════════════════════
// PROVIDER KEYS (BYOK)
// ═══════════════════════════════════════════════════════════════

model ProviderKey {
  id              String    @id @default(cuid())
  userId          String
  provider        String
  encryptedKey    String
  iv              String
  status          String    @default("unconfigured")
  lastValidatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// AGENTS
// ═══════════════════════════════════════════════════════════════

model Agent {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String?
  systemPrompt   String   @db.Text
  model          String   @default("gemini-flash")
  welcomeMessage String?  @db.Text
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]
  channels  Channel[]

  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// KNOWLEDGE BASE
// ═══════════════════════════════════════════════════════════════

model Document {
  id           String         @id @default(cuid())
  agentId      String
  userId       String
  filename     String
  originalName String
  fileType     String
  fileSize     Int
  fileUrl      String
  status       DocumentStatus @default(UPLOADING)
  totalChunks  Int            @default(0)
  errorMsg     String?
  createdAt    DateTime       @default(now())

  agent  Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks DocumentChunk[]

  @@index([agentId])
  @@index([userId])
}

enum DocumentStatus {
  UPLOADING
  EXTRACTING
  EMBEDDING
  INDEXED
  ERROR
}

model DocumentChunk {
  id         String                          @id @default(cuid())
  documentId String
  chunkIndex Int
  content    String                          @db.Text
  embedding  Unsupported("vector(768)")?
  tokenCount Int                             @default(0)
  createdAt  DateTime                        @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// ═══════════════════════════════════════════════════════════════
// CHANNELS (OpenClaw)
// ═══════════════════════════════════════════════════════════════

model Channel {
  id                    String        @id @default(cuid())
  userId                String
  agentId               String
  platform              Platform
  status                ChannelStatus @default(PENDING)
  displayName           String
  platformConfig        Json
  welcomeMessage        String?       @db.Text
  modelOverride         String?
  businessHoursStart    String?
  businessHoursEnd      String?
  businessHoursTimezone String        @default("America/Sao_Paulo")
  respondOutsideHours   Boolean       @default(true)
  outsideHoursMessage   String?       @db.Text
  isActive              Boolean       @default(true)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent         Agent                 @relation(fields: [agentId], references: [id])
  conversations ChannelConversation[]

  @@unique([userId, platform, displayName])
  @@index([userId])
  @@index([platform, status])
}

enum Platform {
  WHATSAPP
  TELEGRAM
  DISCORD
  SLACK
}

enum ChannelStatus {
  PENDING
  CONNECTING
  ACTIVE
  DISCONNECTED
  ERROR
}

model ChannelConversation {
  id               String   @id @default(cuid())
  channelId        String
  externalUserId   String
  externalUserName String?
  startedAt        DateTime @default(now())
  lastMessageAt    DateTime @default(now())
  messageCount     Int      @default(0)
  isActive         Boolean  @default(true)

  channel  Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages ChannelMessage[]

  @@unique([channelId, externalUserId])
  @@index([channelId, lastMessageAt])
}

model ChannelMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  imageUrl       String?
  modelUsed      String?
  tokensIn       Int?
  tokensOut      Int?
  latencyMs      Int?
  createdAt      DateTime    @default(now())

  conversation ChannelConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ═══════════════════════════════════════════════════════════════
// CONVERSATIONS (Web/Desktop)
// ═══════════════════════════════════════════════════════════════

model Conversation {
  id        String             @id @default(cuid())
  userId    String
  agentId   String?
  title     String             @default("Nova conversa")
  source    ConversationSource @default(WEB)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([userId, updatedAt])
}

enum ConversationSource {
  WEB
  DESKTOP
  API
}

model ConversationMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  modelUsed      String?
  tokensIn       Int?
  tokensOut      Int?
  latencyMs      Int?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ═══════════════════════════════════════════════════════════════
// USAGE & BILLING
// ═══════════════════════════════════════════════════════════════

model UsageCounter {
  id           String @id @default(cuid())
  userId       String
  period       String
  messages     Int    @default(0)
  tokensIn     Int    @default(0)
  tokensOut    Int    @default(0)
  byokMessages Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId, period])
}

// ═══════════════════════════════════════════════════════════════
// OUTGOING WEBHOOKS
// ═══════════════════════════════════════════════════════════════

model WebhookEndpoint {
  id        String   @id @default(cuid())
  userId    String
  url       String
  secret    String
  events    String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs WebhookLog[]

  @@index([userId])
}

model WebhookLog {
  id           String    @id @default(cuid())
  endpointId   String
  event        String
  payload      Json
  statusCode   Int?
  responseBody String?   @db.Text
  deliveredAt  DateTime?
  createdAt    DateTime  @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, createdAt])
}

// ═══════════════════════════════════════════════════════════════
// TENANTS (Multi-tenant SaaS)
// ═══════════════════════════════════════════════════════════════

model Tenant {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  softwareName        String?
  softwareDescription String?  @db.Text
  aiSystemPrompt      String?  @db.Text
  plan                String   @default("basic")
  active              Boolean  @default(true)
  settings            Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users              User[]
  clients            Client[]
  tickets            Ticket[]
  categoryTemplates  CategoryTemplate[]
  knowledgeBase      KnowledgeBaseArticle[]
  aiUsageLogs        AiUsageLog[]

  @@index([slug])
}

// ═══════════════════════════════════════════════════════════════
// CLIENTS (End customers of a tenant)
// ═══════════════════════════════════════════════════════════════

model Client {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  document        String?
  email           String?
  phone           String?
  contractPlan    String?
  softwareVersion String?
  environmentJson Json?
  active          Boolean  @default(true)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tickets Ticket[]

  @@index([tenantId])
  @@index([tenantId, name])
}

// ═══════════════════════════════════════════════════════════════
// CATEGORY TEMPLATES (Dynamic form fields per category)
// ═══════════════════════════════════════════════════════════════

model CategoryTemplate {
  id           String   @id @default(cuid())
  tenantId     String
  category     String
  subcategory  String?
  fieldKey     String
  fieldLabel   String
  fieldType    String   @default("text")
  fieldOptions Json?
  placeholder  String?
  required     Boolean  @default(false)
  aiWeight     String   @default("medium")
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, category, fieldKey])
  @@index([tenantId, category, active])
}

// ═══════════════════════════════════════════════════════════════
// KNOWLEDGE BASE ARTICLES (Structured KB with full-text search)
// ═══════════════════════════════════════════════════════════════

model KnowledgeBaseArticle {
  id                 String   @id @default(cuid())
  tenantId           String
  articleNumber      String   @unique
  title              String
  category           String
  subcategory        String?
  softwareName       String?
  versionMin         String?
  versionMax         String?
  problemDescription String   @db.Text
  solutionSteps      String   @db.Text
  solutionType       String?
  notes              String?  @db.Text
  tags               String[] @default([])
  searchVector       Unsupported("tsvector")?
  embedding          Unsupported("vector(1536)")?
  usageCount         Int      @default(0)
  successRate        Decimal  @default(0) @db.Decimal(5, 2)
  status             String   @default("published")
  createdById        String?
  reviewedById       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User?  @relation("KbCreatedBy", fields: [createdById], references: [id])
  reviewedBy User?  @relation("KbReviewedBy", fields: [reviewedById], references: [id])

  @@index([tenantId, category])
  @@index([tenantId, status])
}

// ═══════════════════════════════════════════════════════════════
// TICKETS (Support tickets with structured context)
// ═══════════════════════════════════════════════════════════════

model Ticket {
  id                 String    @id @default(cuid())
  tenantId           String
  ticketNumber       String    @unique
  clientId           String
  attendantId        String
  category           String
  subcategory        String?
  priority           String    @default("medium")
  status             String    @default("open")
  summary            String
  description        String?   @db.Text
  contextJson        Json
  categoryFieldsJson Json?
  errorJson          Json?
  stepsToReproduce   String[]  @default([])
  frequency          String?
  impact             String?
  attachments        Json      @default("[]")
  aiResponseJson     Json?
  aiConfidence       String?
  aiSource           String?
  resolutionNotes    String?   @db.Text
  resolutionCategory String?
  resolvedById       String?
  resolvedAt         DateTime?
  firstResponseAt    DateTime?
  closedAt           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client     Client @relation(fields: [clientId], references: [id])
  attendant  User   @relation("TicketAttendant", fields: [attendantId], references: [id])
  resolvedBy User?  @relation("TicketResolver", fields: [resolvedById], references: [id])
  messages   TicketMessage[]
  aiUsageLogs AiUsageLog[]

  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([clientId])
  @@index([attendantId])
}

// ═══════════════════════════════════════════════════════════════
// TICKET MESSAGES (Conversation timeline within a ticket)
// ═══════════════════════════════════════════════════════════════

model TicketMessage {
  id            String   @id @default(cuid())
  ticketId      String
  senderType    String
  senderId      String?
  content       String   @db.Text
  aiPromptUsed  String?  @db.Text
  aiResponseRaw Json?
  attachments   Json     @default("[]")
  internal      Boolean  @default(false)
  createdAt     DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

// ═══════════════════════════════════════════════════════════════
// AI USAGE LOG (Metrics and audit trail)
// ═══════════════════════════════════════════════════════════════

model AiUsageLog {
  id               String   @id @default(cuid())
  tenantId         String
  ticketId         String?
  modelUsed        String
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  latencyMs        Int?
  confidence       String?
  source           String?
  kbArticlesUsed   String[] @default([])
  feedback         String?
  createdAt        DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ticket Ticket? @relation(fields: [ticketId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
}
