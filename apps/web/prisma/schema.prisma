generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ═══════════════════════════════════════════════════════════════
// USERS & AUTH
// ═══════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  avatarUrl     String?
  planId        PlanTier  @default(FREE)
  planExpiresAt DateTime?
  mpPreapprovalId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  agents           Agent[]
  channels         Channel[]
  apiKeys          ApiKey[]
  usageCounters    UsageCounter[]
  conversations    Conversation[]
  providerKeys     ProviderKey[]
  tenantAiConfig   TenantAiConfig?
  webhookEndpoints WebhookEndpoint[]
  sessions         Session[]
  documents        Document[]
  kbArticles       KnowledgeBaseArticle[]
  kbArticlesUpdated KnowledgeBaseArticle[] @relation("UpdatedBy")
  kbArticlesReviewed KnowledgeBaseArticle[] @relation("ReviewedBy")
  kbCategories     KbCategory[]

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

enum PlanTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// ═══════════════════════════════════════════════════════════════
// API KEYS
// ═══════════════════════════════════════════════════════════════

model ApiKey {
  id         String     @id @default(cuid())
  userId     String
  keyHash    String     @unique
  keyPrefix  String
  name       String
  type       ApiKeyType
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isRevoked  Boolean    @default(false)
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
}

enum ApiKeyType {
  LIVE
  TEST
}

// ═══════════════════════════════════════════════════════════════
// PROVIDER KEYS (BYOK)
// ═══════════════════════════════════════════════════════════════

model ProviderKey {
  id              String    @id @default(cuid())
  userId          String
  provider        String
  encryptedKey    String
  iv              String
  keyMasked       String?
  customBaseUrl   String?
  status          String    @default("unconfigured")
  isValid         Boolean?
  lastValidatedAt DateTime?
  lastUsedAt      DateTime?
  totalRequests   Int       @default(0)
  totalTokensUsed BigInt    @default(0)
  monthlyBudgetUsd Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// AI PROVIDERS & MODELS (multi-provider system)
// ═══════════════════════════════════════════════════════════════

model AiProvider {
  id                  String    @id
  name                String
  icon                String?
  baseUrl             String?
  authType            String    @default("api_key")
  keyPlaceholder      String?
  keyValidationPattern String?
  documentationUrl    String?
  supportsStreaming   Boolean   @default(true)
  supportsVision      Boolean   @default(false)
  supportsTools       Boolean   @default(false)
  active              Boolean   @default(true)
  displayOrder        Int       @default(0)
  createdAt           DateTime  @default(now())

  models AiModel[]
}

model AiModel {
  id                  String    @id
  providerId          String
  name                String
  description         String?
  category            String    @default("chat")
  contextWindow       Int?
  maxOutputTokens     Int?
  inputPricePerMtok   Float?
  outputPricePerMtok  Float?
  supportsStreaming   Boolean   @default(true)
  supportsVision      Boolean   @default(false)
  supportsTools       Boolean   @default(false)
  supportsJsonMode    Boolean   @default(false)
  speedTier           String    @default("medium")
  qualityTier         String    @default("medium")
  recommended         Boolean   @default(false)
  active              Boolean   @default(true)
  displayOrder        Int       @default(0)
  createdAt           DateTime  @default(now())

  provider AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([active])
}

model TenantAiConfig {
  id                    String    @id @default(cuid())
  userId                String    @unique
  defaultProviderId     String?
  defaultModelId        String?
  fallbackProviderId    String?
  fallbackModelId       String?
  temperature           Float     @default(0.30)
  maxTokens             Int       @default(2048)
  systemPromptOverride  String?   @db.Text
  responseLanguage      String    @default("pt-BR")
  requireJsonResponse   Boolean   @default(true)
  enableStreaming        Boolean   @default(true)
  enableKbContext        Boolean   @default(true)
  maxKbArticles         Int       @default(5)
  enableTicketHistory   Boolean   @default(true)
  maxSimilarTickets     Int       @default(3)
  enableCostTracking    Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiUsageLog {
  id           String   @id @default(cuid())
  userId       String
  providerId   String
  modelId      String
  tokensIn     Int      @default(0)
  tokensOut    Int      @default(0)
  costUsd      Float    @default(0)
  latencyMs    Int      @default(0)
  success      Boolean  @default(true)
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, providerId])
}

// ═══════════════════════════════════════════════════════════════
// AGENTS
// ═══════════════════════════════════════════════════════════════

model Agent {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String?
  systemPrompt   String   @db.Text
  model          String   @default("gemini-flash")
  welcomeMessage String?  @db.Text
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents Document[]
  channels  Channel[]

  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// KNOWLEDGE BASE
// ═══════════════════════════════════════════════════════════════

model Document {
  id           String         @id @default(cuid())
  agentId      String
  userId       String
  filename     String
  originalName String
  fileType     String
  fileSize     Int
  fileUrl      String
  status       DocumentStatus @default(UPLOADING)
  totalChunks  Int            @default(0)
  errorMsg     String?
  createdAt    DateTime       @default(now())

  agent  Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks DocumentChunk[]

  @@index([agentId])
  @@index([userId])
}

enum DocumentStatus {
  UPLOADING
  EXTRACTING
  EMBEDDING
  INDEXED
  ERROR
}

model DocumentChunk {
  id         String                          @id @default(cuid())
  documentId String
  chunkIndex Int
  content    String                          @db.Text
  embedding  Unsupported("vector(768)")?
  tokenCount Int                             @default(0)
  createdAt  DateTime                        @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// ═══════════════════════════════════════════════════════════════
// CHANNELS (OpenClaw)
// ═══════════════════════════════════════════════════════════════

model Channel {
  id                    String        @id @default(cuid())
  userId                String
  agentId               String
  platform              Platform
  status                ChannelStatus @default(PENDING)
  displayName           String
  platformConfig        Json
  welcomeMessage        String?       @db.Text
  modelOverride         String?
  businessHoursStart    String?
  businessHoursEnd      String?
  businessHoursTimezone String        @default("America/Sao_Paulo")
  respondOutsideHours   Boolean       @default(true)
  outsideHoursMessage   String?       @db.Text
  isActive              Boolean       @default(true)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent         Agent                 @relation(fields: [agentId], references: [id])
  conversations ChannelConversation[]

  @@unique([userId, platform, displayName])
  @@index([userId])
  @@index([platform, status])
}

enum Platform {
  WHATSAPP
  TELEGRAM
  DISCORD
  SLACK
}

enum ChannelStatus {
  PENDING
  CONNECTING
  ACTIVE
  DISCONNECTED
  ERROR
}

model ChannelConversation {
  id               String   @id @default(cuid())
  channelId        String
  externalUserId   String
  externalUserName String?
  startedAt        DateTime @default(now())
  lastMessageAt    DateTime @default(now())
  messageCount     Int      @default(0)
  isActive         Boolean  @default(true)

  channel  Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages ChannelMessage[]

  @@unique([channelId, externalUserId])
  @@index([channelId, lastMessageAt])
}

model ChannelMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  imageUrl       String?
  modelUsed      String?
  tokensIn       Int?
  tokensOut      Int?
  latencyMs      Int?
  createdAt      DateTime    @default(now())

  conversation ChannelConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ═══════════════════════════════════════════════════════════════
// CONVERSATIONS (Web/Desktop)
// ═══════════════════════════════════════════════════════════════

model Conversation {
  id        String             @id @default(cuid())
  userId    String
  agentId   String?
  title     String             @default("Nova conversa")
  source    ConversationSource @default(WEB)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([userId, updatedAt])
}

enum ConversationSource {
  WEB
  DESKTOP
  API
}

model ConversationMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  modelUsed      String?
  tokensIn       Int?
  tokensOut      Int?
  latencyMs      Int?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ═══════════════════════════════════════════════════════════════
// USAGE & BILLING
// ═══════════════════════════════════════════════════════════════

model UsageCounter {
  id           String @id @default(cuid())
  userId       String
  period       String
  messages     Int    @default(0)
  tokensIn     Int    @default(0)
  tokensOut    Int    @default(0)
  byokMessages Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId, period])
}

// ═══════════════════════════════════════════════════════════════
// OUTGOING WEBHOOKS
// ═══════════════════════════════════════════════════════════════

model WebhookEndpoint {
  id        String   @id @default(cuid())
  userId    String
  url       String
  secret    String
  events    String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs WebhookLog[]

  @@index([userId])
}

model WebhookLog {
  id           String    @id @default(cuid())
  endpointId   String
  event        String
  payload      Json
  statusCode   Int?
  responseBody String?   @db.Text
  deliveredAt  DateTime?
  createdAt    DateTime  @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, createdAt])
}

// ═══════════════════════════════════════════════════════════════
// KB CATEGORIES (customizable per user/tenant)
// ═══════════════════════════════════════════════════════════════

model KbCategory {
  id           String   @id @default(cuid())
  userId       String
  name         String
  slug         String
  icon         String?
  color        String?
  description  String?
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  articles KnowledgeBaseArticle[]

  @@unique([userId, slug])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// KB ARTICLES (knowledge base for AI support)
// ═══════════════════════════════════════════════════════════════

enum KbArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
  DEPRECATED
}

enum KbSolutionType {
  PERMANENT_FIX
  WORKAROUND
  CONFIGURATION
  KNOWN_ISSUE
  INFORMATIONAL
}

enum KbVisibility {
  AI_ONLY
  AGENTS_ONLY
  AI_AND_AGENTS
  PUBLIC
}

model KnowledgeBaseArticle {
  id            String   @id @default(cuid())
  userId        String
  articleNumber String   @unique

  // IDENTIFICATION
  title       String
  categoryId  String
  subcategory String?
  tags        String[] @default([])

  // APPLICATION SCOPE
  softwareName String?
  versionMin   String?
  versionMax   String?
  modules      String[] @default([])
  environments String[] @default([])
  databases    String[] @default([])

  // MAIN CONTENT
  problemDescription String  @db.Text
  rootCause          String? @db.Text
  solutionSteps      String  @db.Text
  solutionType       KbSolutionType @default(PERMANENT_FIX)
  prevention         String? @db.Text
  notes              String? @db.Text

  // TECHNICAL FIELDS
  errorCodes     String[] @default([])
  errorMessages  String[] @default([])
  relatedTables  String[] @default([])
  relatedConfigs String[] @default([])
  sqlQueries     String?  @db.Text
  commands       String?  @db.Text

  // RELATIONSHIPS
  relatedArticleIds String[] @default([])
  supersededById    String?

  // AI CONTEXT
  aiContextNote  String? @db.Text
  priorityWeight Int     @default(50)

  // METRICS
  usageCount           Int      @default(0)
  successCount         Int      @default(0)
  failureCount         Int      @default(0)
  successRate          Float    @default(0)
  lastUsedAt           DateTime?
  avgResolutionMinutes Int?

  // MANAGEMENT
  status     KbArticleStatus @default(DRAFT)
  visibility KbVisibility    @default(AI_AND_AGENTS)

  createdById  String
  updatedById  String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation(fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy  User?       @relation("UpdatedBy", fields: [updatedById], references: [id])
  reviewedBy User?       @relation("ReviewedBy", fields: [reviewedById], references: [id])
  category   KbCategory  @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([userId, status])
  @@index([userId, categoryId])
  @@index([userId, softwareName])
  @@index([tags])
  @@index([errorCodes])
}
