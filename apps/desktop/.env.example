# Algolia Agent Studio credentials
# Obtenha em: https://dashboard.algolia.com/agent-studio
VITE_ALGOLIA_APP_ID=SEU_APP_ID
VITE_ALGOLIA_API_KEY=SUA_API_KEY
VITE_ALGOLIA_AGENT_ID=SEU_AGENT_ID

# Google Gemini API key (com suporte a visão)
# Obtenha em: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=SUA_GEMINI_API_KEY

# Anthropic (Claude) API key
# Obtenha em: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=SUA_ANTHROPIC_API_KEY
